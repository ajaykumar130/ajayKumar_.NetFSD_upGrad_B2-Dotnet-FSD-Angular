@model IEnumerable<DataAccessLayer.Models.ContactInfo>

<h2>Contact List</h2>

<a href="/contact/add">Add New Contact</a>

<table border="1">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Email</th>
        <th>Mobile</th>
        <th>Designation</th>
        <th>Company</th>
        <th>Department</th>
        <th>Actions</th>
    </tr>

@foreach (var item in Model)
{
    <tr>
        <td>@item.ContactId</td>
        <td>@item.FirstName @item.LastName</td>
        <td>@item.EmailId</td>
        <td>@item.MobileNo</td>
        <td>@item.Designation</td>
        <td>@item.CompanyName</td>
        <td>@item.DepartmentName</td>
        <td>
            <a href="/contact/details/@item.ContactId">View</a> |
            <a href="/contact/edit/@item.ContactId">Edit</a> |
            <a href="/contact/delete/@item.ContactId">Delete</a>
        </td>
    </tr>
}
</table>